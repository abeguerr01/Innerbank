<UserControl
  x:Class="Innerbank.Vistas.SeleccionCuenta"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Innerbank.Vistas"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Width="800"
  Height="450"
  mc:Ignorable="d"
>
  <Grid Background="White">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
      Grid.Row="0"
      Margin="10"
      FontSize="24"
      FontWeight="Bold"
      Text="Selecciona una cuenta"
      TextAlignment="Center"
    />
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <StackPanel
        Grid.Column="0"
        Margin="10"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Orientation="Vertical"
      >
        <TextBlock FontSize="30" Text="Crear nueva cuenta" />
        <StackPanel Orientation="Vertical">
          <TextBlock Margin="0,2,0,0" HorizontalAlignment="Left" FontSize="16" Text="Saldo" />
          <TextBox
            Name="tbSaldoCuenta"
            Height="30"
            Margin="0,0,0,5"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding SaldoInicial, UpdateSourceTrigger=LostFocus, TargetNullValue=0}"
          />
        </StackPanel>
        <StackPanel Orientation="Vertical">
          <TextBlock
            Margin="0,2,0,0"
            HorizontalAlignment="Left"
            FontSize="16"
            Text="Cotitular/es"
          />
          <TextBox
            Name="tbCotitulares"
            Height="30"
            Margin="0,0,0,5"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding Cotit, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
          />
        </StackPanel>
        <Button
          Name="btnCrearCuenta"
          Command="{Binding CrearNuevaCuentaComand}"
          Content="Crear cuenta nueva"
          FontSize="24"
        />
      </StackPanel>
      <StackPanel
        Grid.Column="1"
        Margin="10"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Orientation="Vertical"
      >
        <ListView
          Width="300"
          Height="200"
          ItemsSource="{Binding Cuentas}"
          SelectedItem="{Binding CuentaSeleccionada}"
        >
          <ListView.View>
            <GridView>
              <GridViewColumn
                Width="280"
                DisplayMemberBinding="{Binding IDCuenta}"
                Header="Número de cuenta"
              />
            </GridView>
          </ListView.View>
        </ListView>

        <Button
          x:Name="btnSeleccionarCuenta"
          Margin="0,10,0,0"
          Command="{Binding SeleccionarCuentaCommand}"
          Content="Seleccionar cuenta"
          FontSize="24"
        />
      </StackPanel>
    </Grid>
    <Button
      Grid.Row="3"
      Width="150"
      Height="50"
      Margin="0,77,5,0"
      HorizontalAlignment="Right"
      VerticalAlignment="Bottom"
      Command="{Binding CerrarSesion}"
      Content="Cerrar Sesión"
      FontSize="20"
    />
  </Grid>
</UserControl>
