<Window
  x:Class="Innerbank.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:custom="clr-namespace:ModalControl;assembly=ModalControl"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Innerbank"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vistas="clr-namespace:Innerbank.Vistas"
  xmlns:vms="clr-namespace:Innerbank.VistaModelo"
  Title="InnerBank"
  Width="810"
  Height="490"
  MinWidth="810"
  MinHeight="490"
  MaxWidth="810"
  MaxHeight="490"
  d:DataContext="{d:DesignInstance Type=vms:MainVM}"
  mc:Ignorable="d"
>
  <Grid>
    <Grid.Resources>
      <DataTemplate DataType="{x:Type vms:IdentificacionUsuarioVM}">
        <vistas:IdentificacionUsuario />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vms:SeleccionCuentaVM}">
        <vistas:SeleccionCuenta />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vms:ConsultaCuentaVM}">
        <vistas:ConsultarCuenta />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vms:CntraseñaVerTodoVM}">
        <vistas:CntraseñaVerTodo />
      </DataTemplate>
    </Grid.Resources>

    <custom:Modal Panel.ZIndex="10" IsOpen="{Binding IsModalOpen}">
      <ContentControl Content="{Binding CurrentModalViewModel}" />
    </custom:Modal>

    <ContentControl Content="{Binding CuerrentViewModel}" />
  </Grid>
</Window>
