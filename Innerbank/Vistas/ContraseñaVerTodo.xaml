<UserControl
  x:Class="Innerbank.Vistas.CntraseñaVerTodo"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Innerbank.Vistas"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vistamodelo="clr-namespace:Innerbank.VistaModelo"
  d:DataContext="{d:DesignInstance Type=vistamodelo:CntraseñaVerTodoVM}"
  d:DesignHeight="225"
  d:DesignWidth="400"
  mc:Ignorable="d"
>
  <Grid Background="DarkSlateGray">
    <Grid.RowDefinitions>
      <RowDefinition Height="50*" />
      <RowDefinition Height="50*" />
    </Grid.RowDefinitions>

    <Button
      Grid.Row="0"
      Width="20"
      Height="20"
      HorizontalAlignment="Right"
      VerticalAlignment="Top"
      Background="White"
      Command="{Binding CancelarVerTodoCommand}"
      Content="✖"
      Foreground="Black"
    />
    <TextBox
      Grid.Row="0"
      Margin="25,25,25,5"
      HorizontalContentAlignment="Center"
      VerticalContentAlignment="Center"
      Background="WhiteSmoke"
      FontSize="40"
      Foreground="Black"
      Text="{Binding Contraseña, UpdateSourceTrigger=PropertyChanged}"
    />
    <Button
      Grid.Row="1"
      Margin="25,5,25,25"
      Background="Gray"
      Command="{Binding ConfirmarContraseña}"
      Content="ACCEDER"
      FontSize="40"
      Foreground="White"
    />
  </Grid>
</UserControl>
