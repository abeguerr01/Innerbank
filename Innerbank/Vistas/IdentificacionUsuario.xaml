<UserControl
  x:Class="Innerbank.Vistas.IdentificacionUsuario"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Innerbank.Vistas"
  xmlns:lsc="clr-namespace:LoadingSpinnerControl;assembly=LoadingSpinnerControl"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Width="800"
  Height="450"
  mc:Ignorable="d"
>
  <Grid Background="White">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="398.077" />
    </Grid.RowDefinitions>

    <lsc:LoadingSpinner
      Grid.RowSpan="2"
      Panel.ZIndex="10"
      Cap="Round"
      Diameter="200"
      IsLoading="{Binding Cargando, UpdateSourceTrigger=PropertyChanged}"
      Thickness="20"
      Color="MidnightBlue"
    />

    <TextBlock
      Grid.Row="0"
      Margin="10"
      FontSize="24"
      FontWeight="Bold"
      Foreground="MidnightBlue"
      Text="IDENTIFICATE"
      TextAlignment="Center"
    />
    <Button
      Width="80"
      Height="30"
      HorizontalAlignment="Left"
      VerticalAlignment="Top"
      Background="White"
      BorderBrush="LightGray"
      Command="{Binding ContraseñasVerTodo}"
      Content="Ver Datos"
      Foreground="LightGray"
    />

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Grid.Resources>
        <Style TargetType="TextBlock">
          <Setter Property="Foreground" Value="DarkBlue" />
        </Style>

        <Style TargetType="Button">
          <Setter Property="Foreground" Value="White" />
          <Setter Property="Background" Value="DarkCyan" />
        </Style>
      </Grid.Resources>
      <!--  Registrarse  -->
      <StackPanel
        Grid.Column="0"
        Margin="0,0,10,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Orientation="Vertical"
      >
        <TextBlock FontSize="24" Text="Registrarse" />
        <StackPanel Width="320" Margin="5">
          <StackPanel Orientation="Horizontal">
            <StackPanel Width="155" Margin="0,0,5,0">
              <TextBlock Margin="0,2,0,0" HorizontalAlignment="Left" FontSize="16" Text="Nombre" />
              <TextBox
                Name="tbRegNombre"
                Height="30"
                VerticalContentAlignment="Center"
                FontSize="16"
                Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
              />
            </StackPanel>
            <StackPanel Width="155" Margin="5,0,0,0">
              <TextBlock
                Margin="0,2,0,0"
                HorizontalAlignment="Left"
                FontSize="16"
                Text="Apellido"
              />
              <TextBox
                Name="tbRegApellido"
                Height="30"
                VerticalContentAlignment="Center"
                FontSize="16"
                Text="{Binding Apellido, UpdateSourceTrigger=PropertyChanged}"
              />
            </StackPanel>
          </StackPanel>
        </StackPanel>
        <StackPanel Width="320" Margin="5">
          <TextBlock HorizontalAlignment="Left" FontSize="16" Text="DNI" />
          <TextBox
            Name="tbRegDNI"
            Height="30"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding Dni, UpdateSourceTrigger=PropertyChanged}"
          />
        </StackPanel>
        <StackPanel Width="320" Margin="5">
          <TextBlock HorizontalAlignment="Left" FontSize="16" Text="eMail" />
          <TextBox
            Name="tbRegEmail"
            Height="30"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
          />
        </StackPanel>
        <StackPanel Width="320" Margin="5">
          <TextBlock HorizontalAlignment="Left" FontSize="16" Text="Teléfono" />
          <TextBox
            Name="tbRegTlfn"
            Height="30"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding Tlfn, UpdateSourceTrigger=PropertyChanged}"
          />
        </StackPanel>
        <!--  Contraseña  -->
        <StackPanel Margin="5">
          <TextBlock HorizontalAlignment="Left" FontSize="16" Text="Contraseña" />
          <TextBox
            Name="tbRegContraseña"
            Height="30"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding Contraseña, UpdateSourceTrigger=PropertyChanged}"
          />
        </StackPanel>

        <Button
          Width="320"
          Height="40"
          Margin="5"
          Padding="10,5"
          Command="{Binding CrearUsuarioCommand, UpdateSourceTrigger=PropertyChanged}"
          Content="Crear cuenta"
          FontSize="16"
        />
      </StackPanel>
      <!--  Iniciar Sesión  -->
      <StackPanel
        Grid.Column="1"
        Margin="0,0,10,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Orientation="Vertical"
      >
        <TextBlock FontSize="24" Text="Iniciar Sesión" />
        <StackPanel Width="320" Margin="5">
          <TextBlock Margin="0,2,0,0" HorizontalAlignment="Left" FontSize="16" Text="DNI" />
          <TextBox
            Name="tbLogDni"
            Height="30"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding LogDni, UpdateSourceTrigger=PropertyChanged}"
          />
        </StackPanel>
        <StackPanel Width="320" Margin="5">
          <TextBlock Margin="0,2,0,0" HorizontalAlignment="Left" FontSize="16" Text="Contraseña" />
          <TextBox
            Name="tbLogContraseña"
            Height="30"
            VerticalContentAlignment="Center"
            FontSize="16"
            Text="{Binding LogContraseña, UpdateSourceTrigger=PropertyChanged}"
          />
        </StackPanel>
        <Button
          Width="320"
          Height="40"
          Margin="5"
          Padding="10,5"
          Command="{Binding LogUsuarioCommand, UpdateSourceTrigger=PropertyChanged}"
          Content="Iniciar sesion"
          FontSize="16"
        />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
